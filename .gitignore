# Binaries / build outputs
/bin/
/dist/
*.exe
*.test
*.out

# /out/ holds source-of-truth deliverables (user-guide.md, web-help/)
# AND throw-away build artifacts (PRD PDFs, deck, screenshots,
# intermediate previews). Default to ignored; allowlist the
# user-facing pieces we want versioned.
/out/*
!/out/user-guide.md
!/out/user-guide.pdf
!/out/web-help/

# Playwright temp directory created by browser_take_screenshot
.playwright-mcp/

# Local config (may contain secrets)
/config.yaml
/config.local.yaml
*.env
.env
.env.*
!.env.example
!*.env.example

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Go
vendor/
