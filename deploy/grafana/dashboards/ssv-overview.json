{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    {
      "type": "dashboards",
      "title": "SSV",
      "tags": [
        "ssv"
      ],
      "asDropdown": true,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "targetBlank": false
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "Health",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "type": "stat",
      "id": 1,
      "title": "Scrape OK",
      "description": "1 if every collector (inventory, health, performance) succeeded on its last scrape.",
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "min(ssv_up{group=~\"$group\"})",
          "legendFormat": "scrape OK"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red",
                  "index": 0
                },
                "1": {
                  "text": "OK",
                  "color": "green",
                  "index": 1
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Active Alerts",
      "description": "Sum of items in SSV's /alerts endpoint.",
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 3,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(ssv_alerts_total{group=~\"$group\"})"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Servers Online",
      "description": "Number of servers reporting state == 2 (Online).",
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 6,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(ssv_server_state{group=~\"$group\"} == 2)",
          "legendFormat": "online"
        },
        {
          "refId": "B",
          "expr": "count(ssv_server_state{group=~\"$group\"})",
          "legendFormat": "total"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value_and_name",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "id": 4,
      "title": "License Expiry",
      "description": "Days until the soonest server-group license expiry.",
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 9,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "min(ssv_server_group_license_expires_seconds{group=~\"$group\"} - time()) / 86400"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 30
              },
              {
                "color": "green",
                "value": 90
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "id": 5,
      "title": "Total IOPS",
      "description": "Sum of read+write ops/s across all servers.",
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 12,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(ssv_server_read_ops_total{group=~\"$group\"}[1m])) + sum(rate(ssv_server_write_ops_total{group=~\"$group\"}[1m]))"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "iops",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      }
    },
    {
      "type": "stat",
      "id": 6,
      "title": "Throughput",
      "description": "Sum of read+write throughput across all servers.",
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 15,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(ssv_server_read_bytes_total{group=~\"$group\"}[1m])) + sum(rate(ssv_server_write_bytes_total{group=~\"$group\"}[1m]))"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "binBps",
          "decimals": 1,
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          }
        }
      }
    },
    {
      "type": "stat",
      "id": 7,
      "title": "Avg Pool Latency",
      "description": "rate(time) / rate(ops) across all pools.",
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 18,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(rate(ssv_pool_io_time_seconds_total{group=~\"$group\"}[1m]))) / (sum(rate(ssv_pool_read_ops_total{group=~\"$group\"}[1m])) + sum(rate(ssv_pool_write_ops_total{group=~\"$group\"}[1m])))"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.005
              },
              {
                "color": "red",
                "value": 0.008
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "id": 8,
      "title": "Capacity Used",
      "description": "Aggregate pool fill ratio.",
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 21,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(ssv_pool_used_bytes{group=~\"$group\"}) / sum(ssv_pool_capacity_bytes{group=~\"$group\"})"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 70
              },
              {
                "color": "red",
                "value": 85
              }
            ]
          }
        }
      }
    },
    {
      "type": "row",
      "id": 200,
      "title": "Status",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "panels": []
    },
    {
      "type": "table",
      "id": 10,
      "title": "Servers",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "STATE",
          "expr": "ssv_server_state{group=~\"$group\"}",
          "format": "table",
          "instant": true
        },
        {
          "refId": "IOPS",
          "expr": "rate(ssv_server_read_ops_total{group=~\"$group\"}[1m]) + rate(ssv_server_write_ops_total{group=~\"$group\"}[1m])",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
                "server",
                "Value #STATE",
                "Value #IOPS"
              ]
            }
          }
        },
        {
          "id": "merge"
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "server": "Server",
              "Value #STATE": "State",
              "Value #IOPS": "IOPS"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "State"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": {
                        "text": "Unknown",
                        "color": "orange",
                        "index": 0
                      },
                      "1": {
                        "text": "Offline",
                        "color": "red",
                        "index": 1
                      },
                      "2": {
                        "text": "Online",
                        "color": "green",
                        "index": 2
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "IOPS"
            },
            "properties": [
              {
                "id": "unit",
                "value": "iops"
              },
              {
                "id": "decimals",
                "value": 0
              }
            ]
          }
        ]
      }
    },
    {
      "type": "table",
      "id": 11,
      "title": "Pools",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "STATUS",
          "expr": "ssv_pool_status{group=~\"$group\"}",
          "format": "table",
          "instant": true
        },
        {
          "refId": "CAP",
          "expr": "ssv_pool_capacity_bytes{group=~\"$group\"}",
          "format": "table",
          "instant": true
        },
        {
          "refId": "USED",
          "expr": "ssv_pool_used_bytes{group=~\"$group\"}",
          "format": "table",
          "instant": true
        },
        {
          "refId": "IOPS",
          "expr": "rate(ssv_pool_read_ops_total{group=~\"$group\"}[1m]) + rate(ssv_pool_write_ops_total{group=~\"$group\"}[1m])",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
                "pool",
                "Value #STATUS",
                "Value #CAP",
                "Value #USED",
                "Value #IOPS"
              ]
            }
          }
        },
        {
          "id": "merge"
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "pool": "Pool",
              "Value #STATUS": "Status",
              "Value #CAP": "Capacity",
              "Value #USED": "Used",
              "Value #IOPS": "IOPS"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Status"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": {
                        "text": "Running",
                        "color": "green",
                        "index": 0
                      },
                      "1": {
                        "text": "Initializing",
                        "color": "yellow",
                        "index": 1
                      },
                      "4": {
                        "text": "MissingDisks",
                        "color": "red",
                        "index": 2
                      },
                      "5": {
                        "text": "Foreign",
                        "color": "orange",
                        "index": 3
                      },
                      "6": {
                        "text": "Removing",
                        "color": "orange",
                        "index": 4
                      },
                      "7": {
                        "text": "Offline",
                        "color": "red",
                        "index": 5
                      },
                      "8": {
                        "text": "Unknown",
                        "color": "orange",
                        "index": 6
                      },
                      "9": {
                        "text": "FailedRedundancy",
                        "color": "red",
                        "index": 7
                      },
                      "10": {
                        "text": "Suspended",
                        "color": "orange",
                        "index": 8
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Capacity"
            },
            "properties": [
              {
                "id": "unit",
                "value": "bytes"
              },
              {
                "id": "decimals",
                "value": 1
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Used"
            },
            "properties": [
              {
                "id": "unit",
                "value": "bytes"
              },
              {
                "id": "decimals",
                "value": 1
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "IOPS"
            },
            "properties": [
              {
                "id": "unit",
                "value": "iops"
              },
              {
                "id": "decimals",
                "value": 0
              }
            ]
          }
        ]
      }
    },
    {
      "type": "row",
      "id": 300,
      "title": "Workload",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 20,
      "title": "IOPS per server",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 15
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "R",
          "expr": "rate(ssv_server_read_ops_total{group=~\"$group\"}[1m])",
          "legendFormat": "{{server}} read"
        },
        {
          "refId": "W",
          "expr": "rate(ssv_server_write_ops_total{group=~\"$group\"}[1m])",
          "legendFormat": "{{server}} write"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "iops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "axisSoftMin": 0
          }
        }
      }
    },
    {
      "type": "timeseries",
      "id": 21,
      "title": "Throughput per server",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 15
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "R",
          "expr": "rate(ssv_server_read_bytes_total{group=~\"$group\"}[1m])",
          "legendFormat": "{{server}} read"
        },
        {
          "refId": "W",
          "expr": "rate(ssv_server_write_bytes_total{group=~\"$group\"}[1m])",
          "legendFormat": "{{server}} write"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "binBps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "axisSoftMin": 0
          }
        }
      }
    },
    {
      "type": "timeseries",
      "id": 22,
      "title": "Pool latency (avg)",
      "description": "Cumulative time / cumulative ops per pool. Thresholds at 5 ms (warn) and 8 ms (critical).",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 23
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(rate(ssv_pool_read_time_seconds_total{group=~\"$group\"}[1m]) + rate(ssv_pool_write_time_seconds_total{group=~\"$group\"}[1m])) / clamp_min(rate(ssv_pool_read_ops_total{group=~\"$group\"}[1m]) + rate(ssv_pool_write_ops_total{group=~\"$group\"}[1m]), 1)",
          "legendFormat": "{{pool}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 4,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "axisSoftMin": 0,
            "thresholdsStyle": {
              "mode": "line"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.005
              },
              {
                "color": "red",
                "value": 0.008
              }
            ]
          }
        }
      }
    },
    {
      "type": "bargauge",
      "id": 23,
      "title": "Pool fill %",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 23
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * ssv_pool_used_bytes{group=~\"$group\"} / ssv_pool_capacity_bytes{group=~\"$group\"}",
          "legendFormat": "{{pool}}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 70
              },
              {
                "color": "red",
                "value": 85
              }
            ]
          }
        }
      }
    },
