{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "links": [
    {
      "type": "dashboards",
      "title": "SSV",
      "tags": [
        "ssv"
      ],
      "asDropdown": true,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "targetBlank": false
    }
  ],
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "Pool: $pool",
      "collapsed": false,
      "repeat": "pool",
      "repeatDirection": "v",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "stat",
      "id": 10,
      "title": "Status",
      "gridPos": {
        "h": 5,
        "w": 3,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "ssv_pool_status{pool=~\"$pool\",group=~\"$group\"}"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "Running",
                  "color": "green",
                  "index": 0
                },
                "1": {
                  "text": "Initializing",
                  "color": "yellow",
                  "index": 1
                },
                "4": {
                  "text": "MissingDisks",
                  "color": "red",
                  "index": 2
                },
                "5": {
                  "text": "Foreign",
                  "color": "orange",
                  "index": 3
                },
                "6": {
                  "text": "Removing",
                  "color": "orange",
                  "index": 4
                },
                "7": {
                  "text": "Offline",
                  "color": "red",
                  "index": 5
                },
                "8": {
                  "text": "Unknown",
                  "color": "orange",
                  "index": 6
                },
                "9": {
                  "text": "FailedRedundancy",
                  "color": "red",
                  "index": 7
                },
                "10": {
                  "text": "Suspended",
                  "color": "orange",
                  "index": 8
                }
              }
            }
          ]
        }
      }
    },
    {
      "type": "stat",
      "id": 11,
      "title": "Capacity",
      "gridPos": {
        "h": 5,
        "w": 3,
        "x": 3,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "ssv_pool_capacity_bytes{pool=~\"$pool\",group=~\"$group\"}"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "decimals": 1
        }
      }
    },
    {
      "type": "stat",
      "id": 12,
      "title": "Used",
      "gridPos": {
        "h": 5,
        "w": 3,
        "x": 6,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "ssv_pool_used_bytes{pool=~\"$pool\",group=~\"$group\"}"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "decimals": 1
        }
      }
    },
    {
      "type": "stat",
      "id": 13,
      "title": "Free",
      "gridPos": {
        "h": 5,
        "w": 3,
        "x": 9,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "ssv_pool_available_bytes{pool=~\"$pool\",group=~\"$group\"}"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "decimals": 1
        }
      }
    },
    {
      "type": "stat",
      "id": 14,
      "title": "Oversubscribed",
      "description": "Bytes oversubscribed (alarming if > 0).",
      "gridPos": {
        "h": 5,
        "w": 3,
        "x": 12,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "ssv_pool_oversubscribed_bytes{pool=~\"$pool\",group=~\"$group\"}"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "type": "piechart",
      "id": 15,
      "title": "Allocation",
      "gridPos": {
        "h": 5,
        "w": 9,
        "x": 15,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "U",
          "expr": "ssv_pool_used_bytes{pool=~\"$pool\",group=~\"$group\"}",
          "legendFormat": "Used"
        },
        {
          "refId": "F",
          "expr": "ssv_pool_available_bytes{pool=~\"$pool\",group=~\"$group\"}",
          "legendFormat": "Free"
        },
        {
          "refId": "RES",
          "expr": "ssv_pool_reserved_bytes{pool=~\"$pool\",group=~\"$group\"}",
          "legendFormat": "Reserved"
        },
        {
          "refId": "REC",
          "expr": "ssv_pool_reclamation_bytes{pool=~\"$pool\",group=~\"$group\"}",
          "legendFormat": "In reclamation"
        }
      ],
      "options": {
        "pieType": "donut",
        "displayLabels": [
          "percent"
        ],
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value"
          ]
        },
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Used"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#5794F2"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Free"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#73BF69"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Reserved"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#F2495C"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "In reclamation"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#FADE2A"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "timeseries",
      "id": 20,
      "title": "IOPS",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "R",
          "expr": "rate(ssv_pool_read_ops_total{pool=~\"$pool\",group=~\"$group\"}[1m])",
          "legendFormat": "read"
        },
        {
          "refId": "W",
          "expr": "rate(ssv_pool_write_ops_total{pool=~\"$pool\",group=~\"$group\"}[1m])",
          "legendFormat": "write"
        },
        {
          "refId": "T",
          "expr": "rate(ssv_pool_read_ops_total{pool=~\"$pool\",group=~\"$group\"}[1m]) + rate(ssv_pool_write_ops_total{pool=~\"$pool\",group=~\"$group\"}[1m])",
          "legendFormat": "total"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "iops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "axisSoftMin": 0
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "read"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#56A64B"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "write"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#E02F44"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "total"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#3274D9"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "timeseries",
      "id": 21,
      "title": "Latency (read / write)",
      "description": "rate(time)/rate(ops). Thresholds at 5 ms (warn) and 8 ms (critical).",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "R",
          "expr": "rate(ssv_pool_read_time_seconds_total{pool=~\"$pool\",group=~\"$group\"}[1m]) / clamp_min(rate(ssv_pool_read_ops_total{pool=~\"$pool\",group=~\"$group\"}[1m]), 1)",
          "legendFormat": "read"
        },
        {
          "refId": "W",
          "expr": "rate(ssv_pool_write_time_seconds_total{pool=~\"$pool\",group=~\"$group\"}[1m]) / clamp_min(rate(ssv_pool_write_ops_total{pool=~\"$pool\",group=~\"$group\"}[1m]), 1)",
          "legendFormat": "write"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 4,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "axisSoftMin": 0,
            "thresholdsStyle": {
              "mode": "line"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.005
              },
              {
                "color": "red",
                "value": 0.008
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "read"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#56A64B"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "write"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#FF780A"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "table",
      "id": 50,
      "title": "Physical disks of $pool",
      "description": "Pool-member physical disks (Type=4 in /physicalDisks). Tier comes from /poolMembers.",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 13},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "POOL", "expr": "ssv_physical_disk_pool{pool=~\"$pool\",group=~\"$group\"}", "format": "table", "instant": true},
        {"refId": "STATUS", "expr": "ssv_physical_disk_status{group=~\"$group\"} and on(disk_id) ssv_physical_disk_pool{pool=~\"$pool\",group=~\"$group\"}", "format": "table", "instant": true},
        {"refId": "SIZE", "expr": "ssv_physical_disk_size_bytes{group=~\"$group\"} and on(disk_id) ssv_physical_disk_pool{pool=~\"$pool\",group=~\"$group\"}", "format": "table", "instant": true},
        {"refId": "IOPS", "expr": "(rate(ssv_physical_disk_read_ops_total{group=~\"$group\"}[1m]) + rate(ssv_physical_disk_write_ops_total{group=~\"$group\"}[1m])) and on(disk_id) ssv_physical_disk_pool{pool=~\"$pool\",group=~\"$group\"}", "format": "table", "instant": true},
        {"refId": "LAT", "expr": "(rate(ssv_physical_disk_io_time_seconds_total{group=~\"$group\"}[1m]) / clamp_min(rate(ssv_physical_disk_read_ops_total{group=~\"$group\"}[1m]) + rate(ssv_physical_disk_write_ops_total{group=~\"$group\"}[1m]), 1)) and on(disk_id) ssv_physical_disk_pool{pool=~\"$pool\",group=~\"$group\"}", "format": "table", "instant": true}
      ],
      "transformations": [
        {"id": "filterFieldsByName", "options": {"include": {"names": ["disk", "tier", "host_id", "Value #STATUS", "Value #SIZE", "Value #IOPS", "Value #LAT"]}}},
        {"id": "merge"},
        {"id": "organize", "options": {"renameByName": {"disk": "Disk", "tier": "Tier", "host_id": "Host", "Value #STATUS": "Status", "Value #SIZE": "Size", "Value #IOPS": "IOPS", "Value #LAT": "Avg Lat"}, "indexByName": {"disk": 0, "tier": 1, "host_id": 2, "Value #STATUS": 3, "Value #SIZE": 4, "Value #IOPS": 5, "Value #LAT": 6}}}
      ],
      "fieldConfig": {
        "defaults": {"custom": {"align": "auto"}},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Status"},
            "properties": [
              {"id": "mappings", "value": [{"type": "value", "options": {"0": {"text": "Unknown", "color": "orange", "index": 0}, "1": {"text": "Online", "color": "green", "index": 1}, "2": {"text": "Not Ready", "color": "orange", "index": 2}, "3": {"text": "No Media", "color": "orange", "index": 3}, "4": {"text": "Offline", "color": "red", "index": 4}, "5": {"text": "Failed", "color": "red", "index": 5}, "6": {"text": "Failed", "color": "red", "index": 6}}}]},
              {"id": "custom.cellOptions", "value": {"type": "color-background"}}
            ]
          },
          {"matcher": {"id": "byName", "options": "Size"}, "properties": [{"id": "unit", "value": "bytes"}, {"id": "decimals", "value": 1}]},
          {"matcher": {"id": "byName", "options": "IOPS"}, "properties": [{"id": "unit", "value": "iops"}, {"id": "decimals", "value": 0}]},
          {"matcher": {"id": "byName", "options": "Avg Lat"}, "properties": [{"id": "unit", "value": "s"}, {"id": "decimals", "value": 4}]}
        ]
      }
    },
    {
      "type": "timeseries",
      "id": 51,
      "title": "Physical disk IOPS — $pool",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 21},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "R", "expr": "rate(ssv_physical_disk_read_ops_total{group=~\"$group\"}[1m]) and on(disk_id) ssv_physical_disk_pool{pool=~\"$pool\",group=~\"$group\"}", "legendFormat": "{{disk}} read"},
        {"refId": "W", "expr": "rate(ssv_physical_disk_write_ops_total{group=~\"$group\"}[1m]) and on(disk_id) ssv_physical_disk_pool{pool=~\"$pool\",group=~\"$group\"}", "legendFormat": "{{disk}} write"}
      ],
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull", "max"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "fieldConfig": {"defaults": {"unit": "iops", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "axisSoftMin": 0}}}
    },
    {
      "type": "timeseries",
      "id": 52,
      "title": "Physical disk latency — $pool",
      "description": "rate(io_time)/rate(ops) per disk. Thresholds at 5 ms / 8 ms.",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 21},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "(rate(ssv_physical_disk_io_time_seconds_total{group=~\"$group\"}[1m]) / clamp_min(rate(ssv_physical_disk_read_ops_total{group=~\"$group\"}[1m]) + rate(ssv_physical_disk_write_ops_total{group=~\"$group\"}[1m]), 1)) and on(disk_id) ssv_physical_disk_pool{pool=~\"$pool\",group=~\"$group\"}", "legendFormat": "{{disk}}"}
      ],
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull", "max"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 4,
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "axisSoftMin": 0, "thresholdsStyle": {"mode": "line"}},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 0.005}, {"color": "red", "value": 0.008}]}
        }
      }
    },
    {
      "type": "row",
      "id": 200,
      "title": "Virtual Disk: $vdisk",
      "collapsed": false,
      "repeat": "vdisk",
      "repeatDirection": "v",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 29
      }
    },
    {
      "type": "stat",
      "id": 30,
      "title": "Status",
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 0,
        "y": 14
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "ssv_virtual_disk_status{vdisk=~\"$vdisk\",group=~\"$group\"}"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "Online",
                  "color": "green",
                  "index": 0
                },
                "1": {
                  "text": "Offline",
                  "color": "red",
                  "index": 1
                },
                "2": {
                  "text": "Failed Redundancy",
                  "color": "orange",
                  "index": 2
                },
                "3": {
                  "text": "Failed",
                  "color": "red",
                  "index": 3
                },
                "4": {
                  "text": "Unknown",
                  "color": "orange",
                  "index": 4
                }
              }
            }
          ]
        }
      }
    },
    {
      "type": "stat",
      "id": 31,
      "title": "Size",
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 3,
        "y": 14
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "ssv_virtual_disk_size_bytes{vdisk=~\"$vdisk\",group=~\"$group\"}"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "decimals": 1
        }
      }
    },
    {
      "type": "stat",
      "id": 32,
      "title": "Read cache hit",
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 6,
        "y": 14
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * rate(ssv_virtual_disk_cache_read_hits_total{vdisk=~\"$vdisk\",group=~\"$group\"}[1m]) / clamp_min(rate(ssv_virtual_disk_cache_read_hits_total{vdisk=~\"$vdisk\",group=~\"$group\"}[1m]) + rate(ssv_virtual_disk_cache_read_misses_total{vdisk=~\"$vdisk\",group=~\"$group\"}[1m]), 1)"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
