{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "Pool: $pool",
      "collapsed": false,
      "repeat": "pool",
      "repeatDirection": "v",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}
    },
    {
      "type": "stat",
      "id": 10,
      "title": "Status",
      "gridPos": {"h": 5, "w": 3, "x": 0, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "ssv_pool_status{pool=~\"$pool\"}"}],
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "textMode": "value", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {
        "defaults": {
          "mappings": [{"type": "value", "options": {"0": {"text": "Running", "color": "green", "index": 0}, "1": {"text": "Initializing", "color": "yellow", "index": 1}, "4": {"text": "MissingDisks", "color": "red", "index": 2}, "5": {"text": "Foreign", "color": "orange", "index": 3}, "6": {"text": "Removing", "color": "orange", "index": 4}, "7": {"text": "Offline", "color": "red", "index": 5}, "8": {"text": "Unknown", "color": "orange", "index": 6}, "9": {"text": "FailedRedundancy", "color": "red", "index": 7}, "10": {"text": "Suspended", "color": "orange", "index": 8}}}]
        }
      }
    },
    {
      "type": "stat",
      "id": 11,
      "title": "Capacity",
      "gridPos": {"h": 5, "w": 3, "x": 3, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "ssv_pool_capacity_bytes{pool=~\"$pool\"}"}],
      "options": {"colorMode": "value", "graphMode": "none", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "bytes", "decimals": 1}}
    },
    {
      "type": "stat",
      "id": 12,
      "title": "Used",
      "gridPos": {"h": 5, "w": 3, "x": 6, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "ssv_pool_used_bytes{pool=~\"$pool\"}"}],
      "options": {"colorMode": "value", "graphMode": "none", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "bytes", "decimals": 1}}
    },
    {
      "type": "stat",
      "id": 13,
      "title": "Free",
      "gridPos": {"h": 5, "w": 3, "x": 9, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "ssv_pool_available_bytes{pool=~\"$pool\"}"}],
      "options": {"colorMode": "value", "graphMode": "none", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "bytes", "decimals": 1}}
    },
    {
      "type": "stat",
      "id": 14,
      "title": "Oversubscribed",
      "description": "Bytes oversubscribed (alarming if > 0).",
      "gridPos": {"h": 5, "w": 3, "x": 12, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "ssv_pool_oversubscribed_bytes{pool=~\"$pool\"}"}],
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}
        }
      }
    },
    {
      "type": "piechart",
      "id": 15,
      "title": "Allocation",
      "gridPos": {"h": 5, "w": 9, "x": 15, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "U", "expr": "ssv_pool_used_bytes{pool=~\"$pool\"}", "legendFormat": "Used"},
        {"refId": "F", "expr": "ssv_pool_available_bytes{pool=~\"$pool\"}", "legendFormat": "Free"},
        {"refId": "RES", "expr": "ssv_pool_reserved_bytes{pool=~\"$pool\"}", "legendFormat": "Reserved"},
        {"refId": "REC", "expr": "ssv_pool_reclamation_bytes{pool=~\"$pool\"}", "legendFormat": "In reclamation"}
      ],
      "options": {
        "pieType": "donut",
        "displayLabels": ["percent"],
        "legend": {"displayMode": "table", "placement": "right", "values": ["value"]},
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "tooltip": {"mode": "single"}
      },
      "fieldConfig": {
        "defaults": {"unit": "bytes"},
        "overrides": [
          {"matcher": {"id": "byName", "options": "Used"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#5794F2"}}]},
          {"matcher": {"id": "byName", "options": "Free"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#73BF69"}}]},
          {"matcher": {"id": "byName", "options": "Reserved"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#F2495C"}}]},
          {"matcher": {"id": "byName", "options": "In reclamation"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#FADE2A"}}]}
        ]
      }
    },
    {
      "type": "timeseries",
      "id": 20,
      "title": "IOPS",
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 6},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "R", "expr": "rate(ssv_pool_read_ops_total{pool=~\"$pool\"}[5m])", "legendFormat": "read"},
        {"refId": "W", "expr": "rate(ssv_pool_write_ops_total{pool=~\"$pool\"}[5m])", "legendFormat": "write"},
        {"refId": "T", "expr": "rate(ssv_pool_read_ops_total{pool=~\"$pool\"}[5m]) + rate(ssv_pool_write_ops_total{pool=~\"$pool\"}[5m])", "legendFormat": "total"}
      ],
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull", "max"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "fieldConfig": {
        "defaults": {"unit": "iops", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "axisSoftMin": 0}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "read"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#56A64B"}}]},
          {"matcher": {"id": "byName", "options": "write"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#E02F44"}}]},
          {"matcher": {"id": "byName", "options": "total"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#3274D9"}}]}
        ]
      }
    },
    {
      "type": "timeseries",
      "id": 21,
      "title": "Latency (read / write)",
      "description": "rate(time)/rate(ops). Thresholds at 5 ms (warn) and 8 ms (critical).",
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 6},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "R", "expr": "rate(ssv_pool_read_time_seconds_total{pool=~\"$pool\"}[5m]) / clamp_min(rate(ssv_pool_read_ops_total{pool=~\"$pool\"}[5m]), 1)", "legendFormat": "read"},
        {"refId": "W", "expr": "rate(ssv_pool_write_time_seconds_total{pool=~\"$pool\"}[5m]) / clamp_min(rate(ssv_pool_write_ops_total{pool=~\"$pool\"}[5m]), 1)", "legendFormat": "write"}
      ],
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull", "max"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 4,
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "axisSoftMin": 0, "thresholdsStyle": {"mode": "line"}},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 0.005}, {"color": "red", "value": 0.008}]}
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "read"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#56A64B"}}]},
          {"matcher": {"id": "byName", "options": "write"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#FF780A"}}]}
        ]
      }
    },
    {
      "type": "row",
      "id": 200,
      "title": "Virtual Disk: $vdisk",
      "collapsed": false,
      "repeat": "vdisk",
      "repeatDirection": "v",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 13}
    },
    {
      "type": "stat",
      "id": 30,
      "title": "Status",
      "gridPos": {"h": 4, "w": 3, "x": 0, "y": 14},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "ssv_virtual_disk_status{vdisk=~\"$vdisk\"}"}],
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "textMode": "value", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {
        "defaults": {
          "mappings": [{"type": "value", "options": {"0": {"text": "Online", "color": "green", "index": 0}, "1": {"text": "Offline", "color": "red", "index": 1}, "2": {"text": "Failed Redundancy", "color": "orange", "index": 2}, "3": {"text": "Failed", "color": "red", "index": 3}, "4": {"text": "Unknown", "color": "orange", "index": 4}}}]
        }
      }
    },
    {
      "type": "stat",
      "id": 31,
      "title": "Size",
      "gridPos": {"h": 4, "w": 3, "x": 3, "y": 14},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "ssv_virtual_disk_size_bytes{vdisk=~\"$vdisk\"}"}],
      "options": {"colorMode": "value", "graphMode": "none", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "bytes", "decimals": 1}}
    },
    {
      "type": "stat",
      "id": 32,
      "title": "Read cache hit",
      "gridPos": {"h": 4, "w": 3, "x": 6, "y": 14},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "100 * rate(ssv_virtual_disk_cache_read_hits_total{vdisk=~\"$vdisk\"}[5m]) / clamp_min(rate(ssv_virtual_disk_cache_read_hits_total{vdisk=~\"$vdisk\"}[5m]) + rate(ssv_virtual_disk_cache_read_misses_total{vdisk=~\"$vdisk\"}[5m]), 1)"}],
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "orange", "value": 50}, {"color": "green", "value": 80}]}
        }
      }
    },
    {
      "type": "stat",
      "id": 33,
      "title": "Write cache hit",
      "gridPos": {"h": 4, "w": 3, "x": 9, "y": 14},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "100 * rate(ssv_virtual_disk_cache_write_hits_total{vdisk=~\"$vdisk\"}[5m]) / clamp_min(rate(ssv_virtual_disk_cache_write_hits_total{vdisk=~\"$vdisk\"}[5m]) + rate(ssv_virtual_disk_cache_write_misses_total{vdisk=~\"$vdisk\"}[5m]), 1)"}],
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "orange", "value": 50}, {"color": "green", "value": 80}]}
        }
      }
    },
    {
      "type": "stat",
      "id": 34,
      "title": "Avg latency",
      "gridPos": {"h": 4, "w": 3, "x": 12, "y": 14},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "rate(ssv_virtual_disk_io_time_seconds_total{vdisk=~\"$vdisk\"}[5m]) / clamp_min(rate(ssv_virtual_disk_read_ops_total{vdisk=~\"$vdisk\"}[5m]) + rate(ssv_virtual_disk_write_ops_total{vdisk=~\"$vdisk\"}[5m]), 1)"}],
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 4,
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 0.005}, {"color": "red", "value": 0.008}]}
        }
      }
    },
    {
      "type": "timeseries",
      "id": 40,
      "title": "IOPS",
      "gridPos": {"h": 8, "w": 9, "x": 15, "y": 14},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "R", "expr": "rate(ssv_virtual_disk_read_ops_total{vdisk=~\"$vdisk\"}[5m])", "legendFormat": "read"},
        {"refId": "W", "expr": "rate(ssv_virtual_disk_write_ops_total{vdisk=~\"$vdisk\"}[5m])", "legendFormat": "write"},
        {"refId": "T", "expr": "rate(ssv_virtual_disk_read_ops_total{vdisk=~\"$vdisk\"}[5m]) + rate(ssv_virtual_disk_write_ops_total{vdisk=~\"$vdisk\"}[5m])", "legendFormat": "total"}
      ],
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull", "max"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "fieldConfig": {
        "defaults": {"unit": "iops", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "axisSoftMin": 0}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "read"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#56A64B"}}]},
          {"matcher": {"id": "byName", "options": "write"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#E02F44"}}]},
          {"matcher": {"id": "byName", "options": "total"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#3274D9"}}]}
        ]
      }
    },
    {
      "type": "timeseries",
      "id": 41,
      "title": "Throughput",
      "gridPos": {"h": 4, "w": 12, "x": 0, "y": 18},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "R", "expr": "rate(ssv_virtual_disk_read_bytes_total{vdisk=~\"$vdisk\"}[5m])", "legendFormat": "read"},
        {"refId": "W", "expr": "rate(ssv_virtual_disk_write_bytes_total{vdisk=~\"$vdisk\"}[5m])", "legendFormat": "write"}
      ],
      "options": {"legend": {"displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "fieldConfig": {
        "defaults": {"unit": "binBps", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "axisSoftMin": 0}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "read"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#56A64B"}}]},
          {"matcher": {"id": "byName", "options": "write"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#E02F44"}}]}
        ]
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["ssv", "datacore", "storage"],
  "templating": {
    "list": [
      {
        "name": "pool",
        "label": "Pool",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "definition": "label_values(ssv_pool_status, pool)",
        "query": {"qryType": 1, "query": "label_values(ssv_pool_status, pool)", "refId": "PrometheusVariableQueryEditor-VariableQuery"},
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": {"text": "All", "value": "$__all"}
      },
      {
        "name": "topN",
        "label": "Top N vdisks",
        "type": "custom",
        "query": "5,10,20,50",
        "current": {"text": "10", "value": "10"},
        "options": [
          {"text": "5", "value": "5"},
          {"text": "10", "value": "10", "selected": true},
          {"text": "20", "value": "20"},
          {"text": "50", "value": "50"}
        ]
      },
      {
        "name": "vdisk",
        "label": "Virtual Disk (top by IOPS)",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "definition": "query_result(topk($topN, sum by (vdisk) (rate(ssv_virtual_disk_read_ops_total[5m]) + rate(ssv_virtual_disk_write_ops_total[5m]))))",
        "query": {"qryType": 3, "query": "topk($topN, sum by (vdisk) (rate(ssv_virtual_disk_read_ops_total[5m]) + rate(ssv_virtual_disk_write_ops_total[5m])))", "refId": "PrometheusVariableQueryEditor-VariableQuery"},
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "regex": "/vdisk=\"([^\"]+)\"/",
        "current": {"text": "All", "value": "$__all"}
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {"refresh_intervals": ["30s", "1m", "5m", "15m", "30m", "1h"]},
  "title": "SSV — Storage",
  "uid": "ssv-storage",
  "version": 1
}
