  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "Pool: $pool",
      "collapsed": false,
      "repeat": "pool",
      "repeatDirection": "v",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "stat",
      "id": 10,
      "title": "Status",
      "gridPos": {
        "h": 5,
        "w": 3,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "ssv_pool_status{pool=~\"$pool\",group=~\"$group\"}"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "Running",
                  "color": "green",
                  "index": 0
                },
                "1": {
                  "text": "Initializing",
                  "color": "yellow",
                  "index": 1
                },
                "4": {
                  "text": "MissingDisks",
                  "color": "red",
                  "index": 2
                },
                "5": {
                  "text": "Foreign",
                  "color": "orange",
                  "index": 3
                },
                "6": {
                  "text": "Removing",
                  "color": "orange",
                  "index": 4
                },
                "7": {
                  "text": "Offline",
                  "color": "red",
                  "index": 5
                },
                "8": {
                  "text": "Unknown",
                  "color": "orange",
                  "index": 6
                },
                "9": {
                  "text": "FailedRedundancy",
                  "color": "red",
                  "index": 7
                },
                "10": {
                  "text": "Suspended",
                  "color": "orange",
                  "index": 8
                }
              }
            }
          ]
        }
      }
    },
