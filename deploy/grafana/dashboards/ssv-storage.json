    {
      "type": "stat",
      "id": 14,
      "title": "Oversubscribed",
      "description": "Bytes oversubscribed (alarming if > 0).",
      "gridPos": {
        "h": 5,
        "w": 3,
        "x": 12,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "ssv_pool_oversubscribed_bytes{pool=~\"$pool\",group=~\"$group\"}"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "type": "piechart",
      "id": 15,
      "title": "Allocation",
      "gridPos": {
        "h": 5,
        "w": 9,
        "x": 15,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "U",
          "expr": "ssv_pool_used_bytes{pool=~\"$pool\",group=~\"$group\"}",
          "legendFormat": "Used"
        },
        {
          "refId": "F",
          "expr": "ssv_pool_available_bytes{pool=~\"$pool\",group=~\"$group\"}",
          "legendFormat": "Free"
        },
        {
          "refId": "RES",
          "expr": "ssv_pool_reserved_bytes{pool=~\"$pool\",group=~\"$group\"}",
          "legendFormat": "Reserved"
        },
        {
          "refId": "REC",
          "expr": "ssv_pool_reclamation_bytes{pool=~\"$pool\",group=~\"$group\"}",
          "legendFormat": "In reclamation"
        }
      ],
      "options": {
        "pieType": "donut",
        "displayLabels": [
          "percent"
        ],
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value"
          ]
        },
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Used"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#5794F2"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Free"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#73BF69"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Reserved"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#F2495C"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "In reclamation"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#FADE2A"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "timeseries",
      "id": 20,
      "title": "IOPS",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "R",
          "expr": "rate(ssv_pool_read_ops_total{pool=~\"$pool\",group=~\"$group\"}[5m])",
          "legendFormat": "read"
        },
        {
          "refId": "W",
          "expr": "rate(ssv_pool_write_ops_total{pool=~\"$pool\",group=~\"$group\"}[5m])",
          "legendFormat": "write"
        },
        {
          "refId": "T",
          "expr": "rate(ssv_pool_read_ops_total{pool=~\"$pool\",group=~\"$group\"}[5m]) + rate(ssv_pool_write_ops_total{pool=~\"$pool\",group=~\"$group\"}[5m])",
          "legendFormat": "total"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "iops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "axisSoftMin": 0
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "read"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#56A64B"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "write"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#E02F44"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "total"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#3274D9"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "timeseries",
      "id": 21,
      "title": "Latency (read / write)",
      "description": "rate(time)/rate(ops). Thresholds at 5 ms (warn) and 8 ms (critical).",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "R",
          "expr": "rate(ssv_pool_read_time_seconds_total{pool=~\"$pool\",group=~\"$group\"}[5m]) / clamp_min(rate(ssv_pool_read_ops_total{pool=~\"$pool\",group=~\"$group\"}[5m]), 1)",
          "legendFormat": "read"
        },
        {
          "refId": "W",
          "expr": "rate(ssv_pool_write_time_seconds_total{pool=~\"$pool\",group=~\"$group\"}[5m]) / clamp_min(rate(ssv_pool_write_ops_total{pool=~\"$pool\",group=~\"$group\"}[5m]), 1)",
          "legendFormat": "write"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 4,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "axisSoftMin": 0,
            "thresholdsStyle": {
              "mode": "line"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.005
              },
              {
                "color": "red",
                "value": 0.008
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "read"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#56A64B"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "write"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#FF780A"
                }
              }
            ]
          }
        ]
      }
    },
