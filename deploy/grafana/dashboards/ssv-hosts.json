{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "links": [
    {
      "type": "dashboards",
      "title": "SSV",
      "tags": [
        "ssv"
      ],
      "asDropdown": true,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "targetBlank": false
    }
  ],
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "Inventory",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "table",
      "id": 1,
      "title": "Hosts",
      "description": "SAN clients (initiators). State / ConnectionState / Type are vendor-defined enums and rendered as-is.",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "INFO",
          "expr": "ssv_host_info{host=~\"$host\",group=~\"$group\"}",
          "format": "table",
          "instant": true
        },
        {
          "refId": "STATE",
          "expr": "ssv_host_state{host=~\"$host\",group=~\"$group\"}",
          "format": "table",
          "instant": true
        },
        {
          "refId": "MAINT",
          "expr": "ssv_host_maintenance_mode{host=~\"$host\",group=~\"$group\"}",
          "format": "table",
          "instant": true
        },
        {
          "refId": "IOPS",
          "expr": "rate(ssv_host_read_ops_total{host=~\"$host\",group=~\"$group\"}[$__rate_interval]) + rate(ssv_host_write_ops_total{host=~\"$host\",group=~\"$group\"}[$__rate_interval])",
          "format": "table",
          "instant": true
        },
        {
          "refId": "BPS",
          "expr": "rate(ssv_host_read_bytes_total{host=~\"$host\",group=~\"$group\"}[$__rate_interval]) + rate(ssv_host_write_bytes_total{host=~\"$host\",group=~\"$group\"}[$__rate_interval])",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
                "group",
                "host",
                "host_name",
                "description",
                "version",
                "Value #STATE",
                "Value #MAINT",
                "Value #IOPS",
                "Value #BPS"
              ]
            }
          }
        },
        {
          "id": "merge"
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "group": "Group",
              "host": "Host",
              "host_name": "Hostname",
              "description": "Description",
              "version": "Version",
              "Value #STATE": "State",
              "Value #MAINT": "Maint",
              "Value #IOPS": "IOPS",
              "Value #BPS": "B/s"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "State"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": {
                        "text": "Unknown",
                        "color": "orange",
                        "index": 0
                      },
                      "1": {
                        "text": "Offline",
                        "color": "red",
                        "index": 1
                      },
                      "2": {
                        "text": "Online",
                        "color": "green",
                        "index": 2
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Maint"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": {
                        "text": "no",
                        "color": "green",
                        "index": 0
                      },
                      "1": {
                        "text": "YES",
                        "color": "orange",
                        "index": 1
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "IOPS"
            },
            "properties": [
              {
                "id": "unit",
                "value": "iops"
              },
              {
                "id": "decimals",
                "value": 0
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "B/s"
            },
            "properties": [
              {
                "id": "unit",
                "value": "binBps"
              },
              {
                "id": "decimals",
                "value": 1
              }
            ]
          }
        ]
      }
    },
    {
      "type": "row",
      "id": 200,
      "title": "Workload",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      }
    },
    {
      "type": "timeseries",
      "id": 10,
      "title": "IOPS per host",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "R",
          "expr": "rate(ssv_host_read_ops_total{host=~\"$host\",group=~\"$group\"}[$__rate_interval])",
          "legendFormat": "{{host}} read"
        },
        {
          "refId": "W",
          "expr": "rate(ssv_host_write_ops_total{host=~\"$host\",group=~\"$group\"}[$__rate_interval])",
          "legendFormat": "{{host}} write"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "iops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "axisSoftMin": 0
          }
        }
      }
    },
    {
      "type": "timeseries",
      "id": 11,
      "title": "Bandwidth per host",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "R",
          "expr": "rate(ssv_host_read_bytes_total{host=~\"$host\",group=~\"$group\"}[$__rate_interval])",
          "legendFormat": "{{host}} read"
        },
        {
          "refId": "W",
          "expr": "rate(ssv_host_write_bytes_total{host=~\"$host\",group=~\"$group\"}[$__rate_interval])",
          "legendFormat": "{{host}} write"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "binBps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "axisSoftMin": 0
          }
        }
      }
    },
    {
      "type": "row",
      "id": 300,
      "title": "IO size",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 19
      }
    },
    {
      "type": "timeseries",
      "id": 20,
      "title": "Max read size",
      "description": "Peak read IO size observed for each host (gauge).",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "ssv_host_max_read_size_bytes{host=~\"$host\",group=~\"$group\"}",
          "legendFormat": "{{host}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "axisSoftMin": 0
          }
        }
      }
    },
    {
      "type": "timeseries",
      "id": 21,
      "title": "Max write size",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "ssv_host_max_write_size_bytes{host=~\"$host\",group=~\"$group\"}",
          "legendFormat": "{{host}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "axisSoftMin": 0
          }
        }
      }
    },
    {
      "type": "row",
      "id": 400,
      "title": "Provisioning",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 28
      }
    },
    {
      "type": "bargauge",
      "id": 30,
      "title": "Provisioned per host",
      "description": "Total mapped capacity exposed to the SAN client.",
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 29
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "ssv_host_provisioned_bytes{host=~\"$host\",group=~\"$group\"}",
          "legendFormat": "{{host}}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      }
    },
    {
      "type": "row",
      "id": 500,
      "title": "Connections (ports)",
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 38}
    },
    {
      "type": "table",
      "id": 40,
      "title": "Ports of the selected host(s)",
      "description": "Each port belonging to the host(s) selected above. Joined to ssv_host_info via host_id; the host caption is brought in with `* on(host_id) group_left(host)`.",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 39},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "INFO", "expr": "ssv_port_info{group=~\"$group\"} * on(host_id) group_left(host) ssv_host_info{host=~\"$host\",group=~\"$group\"}", "format": "table", "instant": true},
        {"refId": "CONN", "expr": "ssv_port_connected{group=~\"$group\"} * on(host_id) group_left(host) ssv_host_info{host=~\"$host\",group=~\"$group\"}", "format": "table", "instant": true},
        {"refId": "IOPS", "expr": "(rate(ssv_port_read_ops_total{group=~\"$group\"}[$__rate_interval]) + rate(ssv_port_write_ops_total{group=~\"$group\"}[$__rate_interval])) * on(host_id) group_left(host) ssv_host_info{host=~\"$host\",group=~\"$group\"}", "format": "table", "instant": true},
        {"refId": "BPS", "expr": "(rate(ssv_port_read_bytes_total{group=~\"$group\"}[$__rate_interval]) + rate(ssv_port_write_bytes_total{group=~\"$group\"}[$__rate_interval])) * on(host_id) group_left(host) ssv_host_info{host=~\"$host\",group=~\"$group\"}", "format": "table", "instant": true}
      ],
      "transformations": [
        {"id": "filterFieldsByName", "options": {"include": {"names": ["host", "port", "port_type", "port_mode", "port_name", "Value #CONN", "Value #IOPS", "Value #BPS"]}}},
        {"id": "merge"},
        {"id": "organize", "options": {
          "renameByName": {"host": "Host", "port": "Port", "port_type": "Type", "port_mode": "Mode", "port_name": "PortName", "Value #CONN": "Conn", "Value #IOPS": "IOPS", "Value #BPS": "B/s"},
          "indexByName": {"host": 0, "port": 1, "port_type": 2, "port_mode": 3, "port_name": 4, "Value #CONN": 5, "Value #IOPS": 6, "Value #BPS": 7}
        }}
      ],
      "fieldConfig": {
        "defaults": {"custom": {"align": "auto"}},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Conn"},
            "properties": [
              {"id": "mappings", "value": [{"type": "value", "options": {"0": {"text": "no", "color": "red", "index": 0}, "1": {"text": "yes", "color": "green", "index": 1}}}]},
              {"id": "custom.cellOptions", "value": {"type": "color-background"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Type"},
            "properties": [{"id": "mappings", "value": [{"type": "value", "options": {"3": {"text": "iSCSI", "index": 0}, "4": {"text": "FC", "index": 1}}}]}]
          },
          {"matcher": {"id": "byName", "options": "IOPS"}, "properties": [{"id": "unit", "value": "iops"}, {"id": "decimals", "value": 0}]},
          {"matcher": {"id": "byName", "options": "B/s"}, "properties": [{"id": "unit", "value": "binBps"}, {"id": "decimals", "value": 1}]}
        ]
      }
    },
    {
      "type": "timeseries",
      "id": 41,
      "title": "IOPS per port",
      "description": "Per-port IOPS for ports belonging to the selected host(s). Series legend shows the owning host so duplicates like 'vmhba64' across hosts can be told apart.",
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 47},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "R", "expr": "rate(ssv_port_read_ops_total{group=~\"$group\"}[$__rate_interval]) * on(host_id) group_left(host) ssv_host_info{host=~\"$host\",group=~\"$group\"}", "legendFormat": "{{host}} / {{port}} read"},
        {"refId": "W", "expr": "rate(ssv_port_write_ops_total{group=~\"$group\"}[$__rate_interval]) * on(host_id) group_left(host) ssv_host_info{host=~\"$host\",group=~\"$group\"}", "legendFormat": "{{host}} / {{port}} write"}
      ],
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull", "max"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "fieldConfig": {"defaults": {"unit": "iops", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "axisSoftMin": 0}}}
    },
    {
      "type": "timeseries",
      "id": 42,
      "title": "Bandwidth per port",
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 47},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "R", "expr": "rate(ssv_port_read_bytes_total{group=~\"$group\"}[$__rate_interval]) * on(host_id) group_left(host) ssv_host_info{host=~\"$host\",group=~\"$group\"}", "legendFormat": "{{host}} / {{port}} read"},
        {"refId": "W", "expr": "rate(ssv_port_write_bytes_total{group=~\"$group\"}[$__rate_interval]) * on(host_id) group_left(host) ssv_host_info{host=~\"$host\",group=~\"$group\"}", "legendFormat": "{{host}} / {{port}} write"}
      ],
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull", "max"]}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "fieldConfig": {"defaults": {"unit": "binBps", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "axisSoftMin": 0}}}
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [
    "ssv",
    "datacore",
    "hosts"
  ],
  "templating": {
    "list": [
      {
        "name": "group",
        "label": "Group",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "definition": "label_values(ssv_up, group)",
        "query": {
          "qryType": 1,
          "query": "label_values(ssv_up, group)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "multi": false,
        "includeAll": false,
        "current": {}
      },
      {
        "name": "host",
        "label": "Host",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "definition": "label_values(ssv_host_info{group=~\"$group\"}, host)",
        "query": {
          "qryType": 1,
          "query": "label_values(ssv_host_info{group=~\"$group\"}, host)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "30s",
      "1m",
      "5m",
      "15m",
      "30m",
      "1h"
    ]
  },
  "title": "SSV \u2014 Hosts",
  "uid": "ssv-hosts",
  "version": 1
}
