{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "type": "row",
      "id": 1,
      "title": "Server: $server",
      "collapsed": false,
      "repeat": "server",
      "repeatDirection": "v",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}
    },
    {
      "type": "stat",
      "id": 10,
      "title": "State",
      "gridPos": {"h": 4, "w": 3, "x": 0, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "ssv_server_state{server=~\"$server\"}"}],
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "textMode": "value", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {
        "defaults": {
          "mappings": [{"type": "value", "options": {"0": {"text": "Unknown", "color": "orange", "index": 0}, "1": {"text": "Offline", "color": "red", "index": 1}, "2": {"text": "Online", "color": "green", "index": 2}}}],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 2}]}
        }
      }
    },
    {
      "type": "stat",
      "id": 11,
      "title": "Cache",
      "gridPos": {"h": 4, "w": 3, "x": 3, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "ssv_server_cache_state{server=~\"$server\"}"}],
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "textMode": "value", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {
        "defaults": {
          "mappings": [{"type": "value", "options": {"0": {"text": "Unknown", "color": "orange", "index": 0}, "1": {"text": "Disabled", "color": "red", "index": 1}, "2": {"text": "Enabled", "color": "green", "index": 2}}}]
        }
      }
    },
    {
      "type": "stat",
      "id": 12,
      "title": "Power",
      "gridPos": {"h": 4, "w": 3, "x": 6, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "ssv_server_power_state{server=~\"$server\"}"}],
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "textMode": "value", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {
        "defaults": {
          "mappings": [{"type": "value", "options": {"0": {"text": "Unknown", "color": "orange", "index": 0}, "1": {"text": "Loss of AC", "color": "red", "index": 1}, "2": {"text": "AC OK", "color": "green", "index": 2}, "3": {"text": "Low battery", "color": "orange", "index": 3}}}]
        }
      }
    },
    {
      "type": "gauge",
      "id": 13,
      "title": "Cache used",
      "description": "1 - free/total",
      "gridPos": {"h": 4, "w": 4, "x": 9, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "100 * (1 - ssv_server_cache_free_bytes{server=~\"$server\"} / ssv_server_cache_size_bytes{server=~\"$server\"})"}],
      "options": {"orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true, "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 80}, {"color": "red", "value": 95}]}
        }
      }
    },
    {
      "type": "stat",
      "id": 14,
      "title": "Cache size",
      "gridPos": {"h": 4, "w": 3, "x": 13, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "ssv_server_cache_size_bytes{server=~\"$server\"}"}],
      "options": {"colorMode": "value", "graphMode": "none", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "bytes", "decimals": 1}}
    },
    {
      "type": "stat",
      "id": 15,
      "title": "Read cache hit ratio",
      "description": "hits / (hits + misses) over the last 5 minutes.",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "100 * rate(ssv_server_cache_read_hits_total{server=~\"$server\"}[5m]) / clamp_min(rate(ssv_server_cache_read_hits_total{server=~\"$server\"}[5m]) + rate(ssv_server_cache_read_misses_total{server=~\"$server\"}[5m]), 1)"}],
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "orange", "value": 50}, {"color": "green", "value": 80}]}
        }
      }
    },
    {
      "type": "stat",
      "id": 16,
      "title": "Write cache hit ratio",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "100 * rate(ssv_server_cache_write_hits_total{server=~\"$server\"}[5m]) / clamp_min(rate(ssv_server_cache_write_hits_total{server=~\"$server\"}[5m]) + rate(ssv_server_cache_write_misses_total{server=~\"$server\"}[5m]), 1)"}],
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "orange", "value": 50}, {"color": "green", "value": 80}]}
        }
      }
    },
    {
      "type": "timeseries",
      "id": 20,
      "title": "IOPS (read/write)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "R", "expr": "rate(ssv_server_read_ops_total{server=~\"$server\"}[5m])", "legendFormat": "read"},
        {"refId": "W", "expr": "rate(ssv_server_write_ops_total{server=~\"$server\"}[5m])", "legendFormat": "write"},
        {"refId": "T", "expr": "rate(ssv_server_read_ops_total{server=~\"$server\"}[5m]) + rate(ssv_server_write_ops_total{server=~\"$server\"}[5m])", "legendFormat": "total"}
      ],
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull", "max"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "fieldConfig": {
        "defaults": {"unit": "iops", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "axisSoftMin": 0}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "read"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#56A64B"}}]},
          {"matcher": {"id": "byName", "options": "write"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#E02F44"}}]},
          {"matcher": {"id": "byName", "options": "total"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#3274D9"}}]}
        ]
      }
    },
    {
      "type": "timeseries",
      "id": 21,
      "title": "Throughput (read/write)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "R", "expr": "rate(ssv_server_read_bytes_total{server=~\"$server\"}[5m])", "legendFormat": "read"},
        {"refId": "W", "expr": "rate(ssv_server_write_bytes_total{server=~\"$server\"}[5m])", "legendFormat": "write"}
      ],
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull", "max"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "fieldConfig": {
        "defaults": {"unit": "binBps", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "axisSoftMin": 0}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "read"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#56A64B"}}]},
          {"matcher": {"id": "byName", "options": "write"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "#E02F44"}}]}
        ]
      }
    },
    {
      "type": "timeseries",
      "id": 22,
      "title": "IOPS by pipeline class",
      "description": "Operations/s broken down by IO class: front_end_target / mirror_target / physical_disk / pool / target.",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 13},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "rate(ssv_server_class_io_operations_total{server=~\"$server\"}[5m])", "legendFormat": "{{class}}"}],
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull", "max"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "fieldConfig": {
        "defaults": {"unit": "iops", "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "axisSoftMin": 0}}
      }
    },
    {
      "type": "timeseries",
      "id": 23,
      "title": "Avg latency by pipeline class",
      "description": "rate(time)/rate(ops) per class. Thresholds at 5 ms (warn) and 8 ms (critical).",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 13},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "rate(ssv_server_class_io_time_seconds_total{server=~\"$server\"}[5m]) / clamp_min(rate(ssv_server_class_io_operations_total{server=~\"$server\"}[5m]), 1)", "legendFormat": "{{class}}"}],
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull", "max"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 4,
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never", "axisSoftMin": 0, "thresholdsStyle": {"mode": "line"}},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 0.005}, {"color": "red", "value": 0.008}]}
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["ssv", "datacore", "servers"],
  "templating": {
    "list": [
      {
        "name": "server",
        "label": "Server",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "definition": "label_values(ssv_server_state, server)",
        "query": {"qryType": 1, "query": "label_values(ssv_server_state, server)", "refId": "PrometheusVariableQueryEditor-VariableQuery"},
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": {"text": "All", "value": "$__all"}
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {"refresh_intervals": ["30s", "1m", "5m", "15m", "30m", "1h"]},
  "title": "SSV — Servers",
  "uid": "ssv-servers",
  "version": 1
}
