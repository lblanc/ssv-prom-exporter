# Copy to deploy/.env and adjust.

# Where the prometheus container can reach the exporter. Examples:
#   host.docker.internal:9876   # exporter on the same host as docker (default)
#   10.12.104.121:9876          # exporter on a Windows box on the LAN
#   exporter.netbird.luc:9876   # exporter reachable via Netbird DNS
EXPORTER_TARGET=10.12.110.11:9876

# Grafana admin password (anonymous viewer is always on, this gates editing).
GF_ADMIN_PASSWORD=admin
